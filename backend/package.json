{
  "name": "troptions-ucc-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Off-chain hasher and signature packet router for TROPTIONS UCC / NST collateral governance",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "hash": "tsx src/cli-hash.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.19.2",
    "zod": "^3.23.8",
    "multer": "^1.4.5-lts.1",
    "cors": "^2.8.5",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.0",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20"
  }
}
