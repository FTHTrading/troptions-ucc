# Polygon PoS (chain 137) — Mirror Environment (external EVM rail)
# For mirrored reserve + document-hash registries (not the canonical authority).
# Same reserve schema as Apostle. Governed by a separate Safe.

POLYGON_CHAIN_ID=137
POLYGON_RPC_URL=https://polygon-rpc.com                 # or your preferred provider
POLYGON_PRIVATE_KEY=0x...                               # Deployer EOA for initial deployment (transfer to Safe immediately after)
# POLYGON_ETHERSCAN_API_KEY=...                         # For forge verify

# Notes
# - Deploy identical contracts (DocumentHashRegistry + TroptionsReserveRegistry).
# - Admin to a Polygon Safe (see signer manifest coordination with core).
# - Use for external visibility, partner Safes, wallet integrations, and attestation mirrors.
# - Do not use for canonical reserve policy or the 700M pledge authority.